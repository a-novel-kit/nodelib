{
  "name": "nodelib-project",
  "version": "1.3.29",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-novel-kit/nodelib.git"
  },
  "license": "MIT",
  "type": "module",
  "workspaces": [
    ".",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm build:browser && pnpm build:config && pnpm build:node",
    "build:browser": "pnpm compile:browser && pnpm types:browser",
    "build:config": "pnpm compile:config && pnpm types:config",
    "build:node": "pnpm compile:node && pnpm types:node",
    "compile:browser": "rm -rf ./packages/browser/dist && vite build --outDir ./packages/browser/dist -c packages/browser/vite.config.ts",
    "compile:config": "rm -rf ./packages/configs/dist && vite build --outDir ./packages/configs/dist -c packages/configs/vite.config.ts",
    "compile:node": "rm -rf ./packages/test/dist && vite build --outDir ./packages/test/dist -c packages/test/vite.config.ts",
    "format": "prettier --write . --config prettier.config.ts",
    "preinstall": "npx only-allow pnpm",
    "lint": "pnpm lint:stylecheck && pnpm lint:typecheck && pnpm lint:eslint",
    "lint:ci": "pnpm build:config && pnpm build:browser && pnpm lint",
    "lint:eslint": "eslint .",
    "lint:stylecheck": "prettier --check . --config prettier.config.ts",
    "lint:typecheck": "pnpm lint:typecheck:browser && pnpm lint:typecheck:configs && pnpm lint:typecheck:test",
    "lint:typecheck:browser": "pnpm tsc --p ./packages/browser/tsconfig.json --noEmit",
    "lint:typecheck:configs": "pnpm tsc --p ./packages/configs/tsconfig.json --noEmit",
    "lint:typecheck:test": "pnpm tsc --p ./packages/test/tsconfig.json --noEmit",
    "publish:major": "pnpm version major --workspaces --workspaces-update=false --no-git-tag-version && git add -A && git commit -m \"$(node -p \"require('./package.json').version\")\" && git tag v$(node -p \"require('./package.json').version\") && git push && git push --tags",
    "publish:minor": "pnpm version minor --workspaces --workspaces-update=false --no-git-tag-version && git add -A && git commit -m \"$(node -p \"require('./package.json').version\")\" && git tag v$(node -p \"require('./package.json').version\") && git push && git push --tags",
    "publish:patch": "pnpm version patch --workspaces --workspaces-update=false --no-git-tag-version && git add -A && git commit -m \"$(node -p \"require('./package.json').version\")\" && git tag v$(node -p \"require('./package.json').version\") && git push && git push --tags",
    "test": "vitest run",
    "test:ci": "pnpm build:config && pnpm build:browser && pnpm test",
    "types:browser": "tsc --build packages/browser/tsconfig.build.json",
    "types:config": "tsc --build packages/configs/tsconfig.build.json",
    "types:node": "tsc --build packages/test/tsconfig.build.json"
  },
  "devDependencies": {
    "@a-novel-kit/nodelib-config": "catalog:",
    "@eslint/config-helpers": "catalog:",
    "@eslint/js": "catalog:",
    "@trivago/prettier-plugin-sort-imports": "catalog:",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "4.1.2",
    "cookie": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "^17.0.0",
    "jiti": "catalog:",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-packagejson": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "^8.0.0",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.9.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ],
    "overrides": {
      "brace-expansion@<5.0.5": ">=5.0.5",
      "cookie@<0.7.0": ">=0.7.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@>=1.0.0 <1.10.3": ">=1.10.3"
    }
  }
}
